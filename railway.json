{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "phases": {
        "setup": {
          "nixPkgs": [
            "php83",
            "php83Extensions.pdo",
            "php83Extensions.pgsql",
            "nginx"
          ]

        }
      }
    }
  },
  "deploy": {
    "startCommand": "bash start.sh",
    "restartPolicyType": "ON_FAILURE"
  }
}
