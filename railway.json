{
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfig": {
      "providers": [],
      "phases": {
        "setup": {
          "nixPkgs": [
            "php",
            "phpExtensions.fpm",
            "phpExtensions.pgsql",
            "phpExtensions.pdo",
            "nginx"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "bash start.sh",
    "restartPolicyType": "ON_FAILURE"
  }
}
